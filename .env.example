# Variáveis de Ambiente - WhatsApp API (joaosilva-source/whatsapp-api)

# Servidor
PORT=3000

# Painel de Solicitações - URL base do painel (sem barra no final)
# A API chama POST {PANEL_URL}/api/requests/auto-status quando alguém reage com ✅ ou ❌
# Exemplo com painel no Netlify:
PANEL_URL=https://painel-velotax.netlify.app

# URL pública da API (para log "API ONLINE" e ping interno). Use quando rodar com ngrok.
# Exemplo:
API_PUBLIC_URL=https://carmina-peskier-balletically.ngrok-free.dev
# Ou NGROK_URL (mesmo valor)

# Stream de respostas citadas (opcional): 1 para enviar ao painel POST /api/requests/reply
REPLIES_STREAM_ENABLED=0

# Ping automático (evitar sleep no Render): false para desativar
PING_ENABLED=true
PING_INTERVAL=600000
PING_DELAY=60000
